# AI Service Environment Variables

# ========================================
# OpenAI Configuration
# ========================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ========================================
# Model Paths
# ========================================
MODEL_PATH=./models
EMOTION_MODEL_PATH=./models/emotion_detection.pkl
SENTIMENT_MODEL_PATH=./models/sentiment_analysis.pkl

# ========================================
# Server Configuration
# ========================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info

# ========================================
# Python Configuration
# ========================================
PYTHONUNBUFFERED=1
PYTHONPATH=.

# ========================================
# Audio Processing
# ========================================
AUDIO_MAX_DURATION=60
AUDIO_MAX_SIZE=5242880
AUDIO_SAMPLE_RATE=16000

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_PER_MINUTE=60
EMOTION_ANALYSIS_LIMIT=100
RESPONSE_GENERATION_LIMIT=50

# ========================================
# Cache Configuration
# ========================================
ENABLE_CACHE=true
CACHE_TTL=3600

# ========================================
# Model Configuration
# ========================================
USE_GPU=false
BATCH_SIZE=32
MAX_SEQUENCE_LENGTH=512

# ========================================
# Language Support
# ========================================
SUPPORTED_LANGUAGES=en,ar
DEFAULT_LANGUAGE=en

# ========================================
# Monitoring
# ========================================
ENABLE_METRICS=true
SENTRY_DSN=

# ========================================
# Development
# ========================================
DEBUG=false
RELOAD=true
