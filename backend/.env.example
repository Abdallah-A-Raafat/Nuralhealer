# Backend Environment Variables

# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=5000

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://username:password@localhost:5432/neuralhealer
# For development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neuralhealer

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://localhost:6379
# For Redis Cloud or ElastiCache
# REDIS_URL=redis://username:password@host:port

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# AI Service Configuration
# ========================================
AI_SERVICE_URL=http://localhost:8000
# For production
# AI_SERVICE_URL=https://ai.neuralhealer.com

# ========================================
# Email Configuration (Optional)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@neuralhealer.com

# ========================================
# File Upload Configuration
# ========================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ========================================
# CORS Configuration
# ========================================
CORS_ORIGIN=http://localhost:5173
# For production (comma-separated)
# CORS_ORIGIN=https://neuralhealer.com,https://www.neuralhealer.com

# ========================================
# Logging
# ========================================
LOG_LEVEL=debug
# Options: error, warn, info, debug

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# Session Configuration
# ========================================
SESSION_SECRET=your-session-secret-key
SESSION_MAX_AGE=86400000

# ========================================
# Payment Gateway (Optional)
# ========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ========================================
# Push Notifications (Optional)
# ========================================
FCM_SERVER_KEY=your-firebase-server-key
APNS_KEY_ID=your-apple-key-id
APNS_TEAM_ID=your-apple-team-id

# ========================================
# Monitoring & Analytics (Optional)
# ========================================
SENTRY_DSN=https://...@sentry.io/...
GOOGLE_ANALYTICS_ID=UA-...

# ========================================
# Development Flags
# ========================================
ENABLE_API_DOCS=true
ENABLE_CORS=true
ENABLE_LOGGING=true
