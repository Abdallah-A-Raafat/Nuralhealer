# Mobile App Environment Variables

# ========================================
# API Configuration
# ========================================
API_URL=http://localhost:5000/api
AI_API_URL=http://localhost:8000

# For production
# API_URL=https://api.neuralhealer.com
# AI_API_URL=https://ai.neuralhealer.com

# ========================================
# App Configuration
# ========================================
APP_NAME=NeuralHealer
APP_VERSION=1.0.0
BUNDLE_ID=com.neuralhealer.app

# ========================================
# Features Flags
# ========================================
ENABLE_MOCK_DATA=false
ENABLE_VOICE_CHAT=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true

# ========================================
# Firebase Configuration
# ========================================
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ========================================
# Push Notifications
# ========================================
FCM_SENDER_ID=

# ========================================
# Analytics
# ========================================
GOOGLE_ANALYTICS_TRACKING_ID=
MIXPANEL_TOKEN=

# ========================================
# Sentry Error Tracking
# ========================================
SENTRY_DSN=

# ========================================
# In-App Purchases (Optional)
# ========================================
STRIPE_PUBLISHABLE_KEY=

# ========================================
# Social Login (Optional)
# ========================================
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
APPLE_CLIENT_ID=

# ========================================
# Map Services (Optional)
# ========================================
GOOGLE_MAPS_API_KEY=

# ========================================
# Deep Linking
# ========================================
URL_SCHEME=neuralhealer
DEEP_LINK_DOMAIN=neuralhealer.com
