# ======================================================
# BACKEND SWITCH — to use ngrok, comment out LOCAL block
# and uncomment NGROK block (replace the URL each time)
# ======================================================

# --- LOCAL (same machine) ---
 VITE_API_BASE_URL=http://localhost:8080/api
 VITE_WS_URL=ws://localhost:8080/api/ws

# --- NGROK (friend's machine — update URL after each ngrok restart) ---
#VITE_API_BASE_URL=https://nonevaporating-lora-nonranging.ngrok-free.dev/api
#VITE_WS_URL=wss://nonevaporating-lora-nonranging.ngrok-free.dev/api/ws

VITE_API_TIMEOUT=30000

# ======================================================
# TURN SERVER (optional but required on corporate/mobile networks)
# Without TURN, ~15-20% of calls using symmetric NAT will fail.
# Free option: https://www.metered.ca/tools/openrelay/
# Self-hosted: coturn (open source)
# ======================================================
# VITE_TURN_URL=turn:your-turn-server.com:3478
# VITE_TURN_USERNAME=youruser
# VITE_TURN_CREDENTIAL=yourpassword
